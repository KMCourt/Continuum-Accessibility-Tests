# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Testmail.app credentials (for OTP flows)
TESTMAIL_API_KEY=your_api_key_here
TESTMAIL_NAMESPACE=your_namespace_here
TESTMAIL_TAG=your_tag_here

# Microsoft Teams webhook (optional — for scan result notifications)
TEAMS_WEBHOOK_URL=your_webhook_url_here
